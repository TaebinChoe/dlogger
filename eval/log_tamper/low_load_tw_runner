#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

pcpu_buf=1.6
iterations=1
wakeup_int=1
rbuf=16
defense="prevention"
cache_time=667000
flush_interval=0.001
test_duration=180
log_mode="local"
ssh_user=""
ssh_server=""

if [[ $# == 0 || $# -gt 9 || "x$1" == 'x-h' || "x$1" == 'x-help' || "x$1" == 'x--help' ]]; then
    echo "Usage: $0 outfile [iterations [defense [cache_time [flush_interval"
    echo "                 [test_duration [log_mode [ssh_user [ssh_server]]]]]]]]"
    echo
    echo "  Defaults:"
    echo "  iterations = $iterations times"
    echo "  defense = $defense (prevention|detection)"
    echo "  cache_time = $cache_time us"
    echo "  flush_interval = $flush_interval  seconds"
    echo "  test_duration = $test_duration seconds"
    echo "  log_mode=$log_mode   (local|remote)"
    echo "  ssh_user=$ssh_user"
    echo "  ssh_server=$ssh_server"
    echo
    echo "  Examples:"
    echo "  Local :  $0 out.csv 1 prevention 670000 0.001 180 local"
    echo "  Remote:  $0 out.csv 1 prevention 670000 0.001 180 remote user host"
    exit 1
fi

outfile="$1"
iterations=${2:-$iterations}
defense=${3:-$defense}
cache_time=${4:-$cache_time}
flush_interval=${5:-$flush_interval}
test_duration=${6:-$test_duration}
log_mode=${7:-$log_mode}
ssh_user=${8:-"$ssh_user"}
ssh_server=${9:-"$ssh_server"}


logfile="/tmp/$outfile.log"
agoutfile="/tmp/$outfile.ag"
diag_prefix="eaudit_diagnostic:"
parserFile="/tmp/$outfile.prt"

if [[ "${outfile##*.}" != "csv" ]]; then
    echo "outfile should have a .csv suffix" && exit 1
fi

if [[ "$log_mode" != "local" && "$log_mode" != "remote" ]]; then
    echo "log_mode must be 'local' or 'remote'" >&2
    exit 1
fi

if [[ "$defense" != "prevention" && "$defense" != "detection" ]]; then
    echo "defense must be 'prevention' or 'detection'" >&2
    exit 1
fi

if [[ "$log_mode" == "remote" && ( -z "${ssh_user:-}" || -z "${ssh_server:-}" ) ]]; then
    echo "remote log_mode requires <ssh_user> <ssh_server>" >&2
    exit 1
fi

require_sudo() {
    if (( "$(id -u)" != 0 )); then
        sudo -v || {
            echo "sudo authentication failed; aborting before starting logger" >&2
            exit 1
        }
    fi
}

require_sudo

(cd "$ROOT_DIR" && make all) || exit 1
if [ "$defense" = "detection" ]; then
    (cd "$ROOT_DIR" && make eauditd-tamper) || exit 1
fi

agent_stats() {
    require_sudo

    if [[ "$log_config" == ssh://* ]]; then
        scp "$ssh_user@$ssh_server:$logfile" "$logfile"
    fi

    if [ "$defense" = "detection" ] && [ "$param_config" != "-A 0" ]; then
        (cd "$ROOT_DIR" && sudo ./eaudit -I "$logfile" -L -V) &> "$parserFile"
    else
        (cd "$ROOT_DIR" && sudo ./eaudit -I "$logfile") &> "$parserFile"
    fi

    tamper_avg_time=$(grep -a -o -E 'Avg tamper window [0-9]+(\.[0-9]+)?+' "$parserFile" | awk '{print $4}')
    echo -n "$tamper_avg_time,$cache_time,$flush_interval" >> "$outf"
}

agent() {
    require_sudo

   
     if [ "$param_config" = "-A 0" ]; then
        args_prefix="-m $diag_prefix -s -v2 -b $pcpu_buf -r $rbuf -w $wakeup_int -C"
        args_suffix="-- -C $log_config"
    elif [ "$param_config" = "-A 1" ]; then
        args_prefix="-m $diag_prefix -s -v2 -b $pcpu_buf -r $rbuf -w $wakeup_int $param_config -t $cache_time"
        args_suffix="-- -C $log_config"
    elif [ "$param_config" = "-A 2" ]; then
        args_prefix="-m $diag_prefix -s -v2 -b $pcpu_buf -r $rbuf -w $wakeup_int $param_config -t $cache_time"
        args_suffix="-- -C $log_config -f $flush_interval"
    else
        args_prefix="-m $diag_prefix -s -v2 -b $pcpu_buf -r $rbuf -w $wakeup_int $param_config -t $cache_time"
        args_suffix="-- -C $log_config -f $flush_interval"
    fi

    if [ "$defense" = "detection" ] && [ "$param_config" != "-A 0" ]; then
        args="$args_prefix -H $args_suffix"
    else
        args="$args_prefix $args_suffix"
    fi
    
    # echo  "Logger Config::$args"
    ( cd "$ROOT_DIR" && ./ecapd $args >& "$agoutfile" ) &
    agent_pid=$!
    echo ":Running the logger in background for $test_duration s"
    sleep $test_duration
    if ! kill -0 "$agent_pid" 2>/dev/null; then
        echo "failed: logger exited before test completed; see $agoutfile" >&2
        exit 1
    fi
    require_sudo
    wrapper=sudo
    if (( "$(id -u)" == 0 )); then
        wrapper=
    fi

    kill_tree() {
        local pid="$1"
        local child
        for child in $(pgrep -P "$pid" 2>/dev/null); do
            kill_tree "$child"
        done
        $wrapper kill "$pid" 2>/dev/null || true
    }

    if [[ "$log_config" == ssh://* ]]; then
        pkill -9 -f "ssh .*${outfile}" 2>/dev/null || true
    fi
    kill_tree "$agent_pid"
    wait "$agent_pid" 2>/dev/null || true
    	
    sleep 15
    agent_stats
}

loop_body() {
   
    echo -n "log=$log_config :::  Iteration: $i ::: Algorithm=$param_config"
    echo -n "$param_config,$log_config,$defense,$i," >> "$outf"
    agent
    sleep 20
    echo ""
    echo "" >> "$outf"
}
outf=$outfile

# Create output CSV with headers if it doesn't exist
if [ ! -f "$outf" ]; then
    echo "e_config,log_config,defense,trial,avg_tw,cachetime,flush_int" > "$outf"
fi
################################################################################
# Can change which algorithm to flush with, default measures all algorithm
# A 0 = eaudit, A 1 = Community, A 2 = user-level, A 3 = hybrid
################################################################################
# declare -a param_configs=("-A 2" "-A 3")
# declare -a param_configs=("-A 0")
declare -a param_configs=("-A 0" "-A 1" "-A 2" "-A 3")

if [ "$log_mode" = "local" ]; then
    declare -a log_configs=("$logfile")
else
    declare -a log_configs=("ssh://$ssh_user@$ssh_server/$logfile")
fi

for (( i=0; i < $iterations; i++ )); do
    for log_config in "${log_configs[@]}"; do
        for param_config in "${param_configs[@]}"; do
                loop_body
        done
    done
done
